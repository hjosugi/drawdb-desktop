{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "drawDB",
  "version": "1.7.0",
  "identifier": "app.drawdb.desktop",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "drawDB",
        "width": 1366,
        "height": 850,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi",
      "deb",
      "appimage",
      "dmg"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Database schema editor",
    "longDescription": "drawDB - Free and simple database diagram editor and SQL generator",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "fileAssociations": [
      {
        "ext": [
          "ddb"
        ],
        "name": "drawDB Diagram",
        "description": "drawDB diagram file",
        "role": "Editor",
        "mimeType": "application/json"
      },
      {
        "ext": [
          "ddbpack"
        ],
        "name": "drawDB Project Pack",
        "description": "drawDB project package",
        "role": "Editor",
        "mimeType": "application/zip"
      }
    ],
    "windows": {
      "wix": {
        "language": [
          "en-US",
          "ja-JP"
        ]
      },
      "nsis": {
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      }
    }
  }
}