{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "drawDB desktop default capabilities",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$DOCUMENT/**"
        },
        {
          "path": "$DESKTOP/**"
        },
        {
          "path": "$DOWNLOAD/**"
        },
        {
          "path": "$HOME/drawDB/**"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$APPCONFIG/**"
        }
      ]
    },
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close"
  ]
}